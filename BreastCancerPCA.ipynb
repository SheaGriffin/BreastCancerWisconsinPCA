   "source": [
    "#BREAST CANCER WISCONSON DATA - LOAD/INITIALIZE\n",
    "from sklearn.datasets import load_breast_cancer\n",
    "bc_df = load_breast_cancer(as_frame=True)\n",
    "bc_df = bc_df.frame\n",
    "#flip 1 and 0 for y - currently 1=benign and 0=malignant\n",
    "#1 for malignant makes more sense as it indicates being \"positive\" for cancer\n",
    "bc_df['target'] = 1 - bc_df['target']\n",
    "\n",
    "\n",
    "\n",
    "#FEATURE EDA\n",
    "#split features and target\n",
    "X = bc_df.drop('target', axis=1)\n",
    "y = bc_df['target']\n",
    "\n",
    "#examine distribution of features\n",
    "X.hist(bins=50, figsize=(20,15))\n",
    "plt.suptitle('Distribution of Features', fontsize=32, fontweight='bold',y=.95)\n",
    "plt.show()\n",
    "\n",
    "#examine correlation\n",
    "bc_corr = bc_df.corr()\n",
    "corr_mask = np.zeros_like(bc_corr, dtype=bool)\n",
    "corr_mask[np.triu_indices_from(corr_mask)] = True\n",
    "fig, ax = plt.subplots(figsize=(15,15))\n",
    "sns.heatmap(bc_corr.round(2), mask=corr_mask, cmap=sns.diverging_palette(20, 220, as_cmap=True), vmax=1.0,\n",
    "            annot=True, center=0, square=True, linewidths=.5, cbar_kws={\"shrink\": .5}, annot_kws={\"size\": 8})\n",
    "plt.title('Correlation Heatmap', fontsize=24, fontweight='bold')\n",
    "plt.show()\n",
    "\n",
    "#apply standard scaler to normalize data\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X)\n"
   ]
  },
